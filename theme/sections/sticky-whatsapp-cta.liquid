{%- liquid
  assign wa_phone = section.settings.phone | default: settings.whatsapp_phone
  assign wa_default_message = section.settings.default_message | default: settings.whatsapp_message | default: 'Hi Morbeez, I need help with '
-%}
{%- if section.settings.enabled and wa_phone != blank -%}
  {%- capture wa_message -%}
    {{ wa_default_message }}{{ request.page_type }}
  {%- endcapture -%}
  {%- assign wa_url = 'https://wa.me/' | append: wa_phone | remove: '+' | remove: ' ' | remove: '-' -%}
  {%- assign wa_url = wa_url | append: '?text=' | append: wa_message | url_encode -%}

  <div
    class="fixed z-50"
    style="bottom: calc(1.25rem + env(safe-area-inset-bottom, 0px)); right: 1.25rem;"
    data-morbeez-whatsapp-cta
    {{ section.shopify_attributes }}
  >
    <a
      href="{{ wa_url }}"
      target="_blank"
      rel="noopener noreferrer"
      class="morbeez-btn-whatsapp flex h-14 w-14 items-center justify-center rounded-full p-0 shadow-lg md:h-auto md:w-auto md:rounded-full md:px-5"
      aria-label="{{ 'general.whatsapp.contact' | t }}"
    >
      {%- render 'morbeez-icon', name: 'whatsapp', class: 'h-6 w-6 md:h-5 md:w-5' -%}
      <span class="hidden font-semibold md:inline">{{ 'general.whatsapp.label' | t }}</span>
    </a>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.sticky_whatsapp.name",
  "tag": "section",
  "class": "section-sticky-whatsapp",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "t:sections.sticky_whatsapp.settings.enabled", "default": true },
    {
      "type": "text",
      "id": "phone",
      "label": "t:sections.sticky_whatsapp.settings.phone",
      "info": "t:sections.sticky_whatsapp.settings.phone_info",
      "default": "919999999999"
    },
    {
      "type": "textarea",
      "id": "default_message",
      "label": "t:sections.sticky_whatsapp.settings.default_message",
      "default": "Hi Morbeez, I need help with "
    }
  ]
}
{% endschema %}
