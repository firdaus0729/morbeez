<footer class="border-t border-gray-100 bg-[var(--color-surface)] morbeez-section" role="contentinfo">
  <div class="morbeez-container grid gap-8 md:grid-cols-4">
    <div>
      <p class="font-heading font-bold text-lg text-[var(--color-primary)]">{{ shop.name }}</p>
      <p class="mt-2 text-sm text-[var(--color-muted)]">{{ section.settings.tagline }}</p>
    </div>
    {%- for block in section.blocks -%}
      {%- if block.type == 'menu' -%}
        <div {{ block.shopify_attributes }}>
          <h3 class="text-sm font-semibold">{{ block.settings.heading }}</h3>
          <ul class="mt-3 space-y-2" role="list">
            {%- for link in linklists[block.settings.menu].links -%}
              <li><a href="{{ link.url }}" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-primary)]">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
  <div class="morbeez-container mt-8 flex flex-col items-center justify-between gap-4 border-t border-gray-200 pt-6 sm:flex-row">
    <p class="text-xs text-[var(--color-muted)]">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</p>
    {%- render 'morbeez-language-switcher' -%}
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    { "type": "text", "id": "tagline", "label": "t:sections.footer.settings.tagline", "default": "Premium agriculture solutions" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "t:sections.footer.blocks.menu.name",
      "settings": [
        { "type": "text", "id": "heading", "label": "t:sections.footer.blocks.menu.settings.heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "t:sections.footer.blocks.menu.settings.menu" }
      ]
    }
  ],
  "presets": [{ "name": "t:sections.footer.presets.default" }]
}
{% endschema %}
