{%- liquid
  assign fetch = 'high'
  assign loading = 'eager'
-%}

<section class="morbeez-section relative overflow-hidden bg-[var(--color-surface)]" id="MorbeezHero-{{ section.id }}">
  <div class="morbeez-container">
    <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-12">
      <div class="order-2 lg:order-1">
        {%- if section.settings.badge != blank -%}
          <span class="mb-3 inline-block rounded-full bg-[var(--color-accent)]/20 px-3 py-1 text-xs font-semibold text-[var(--color-primary)]">
            {{ section.settings.badge }}
          </span>
        {%- endif -%}
        <h1 class="font-heading text-3xl font-bold leading-tight text-[var(--color-trust)] sm:text-4xl lg:text-5xl">
          {{ section.settings.heading }}
        </h1>
        {%- if section.settings.subheading != blank -%}
          <div class="mt-4 text-base text-[var(--color-muted)] prose prose-sm max-w-none">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}
        <div class="mt-6 flex flex-wrap gap-3">
          {%- if section.settings.primary_cta_url != blank -%}
            {%- render 'morbeez-button',
              url: section.settings.primary_cta_url,
              label: section.settings.primary_cta_label,
              style: 'primary'
            -%}
          {%- endif -%}
          {%- if section.settings.secondary_cta_url != blank -%}
            {%- render 'morbeez-button',
              url: section.settings.secondary_cta_url,
              label: section.settings.secondary_cta_label,
              style: 'secondary'
            -%}
          {%- endif -%}
        </div>
        {%- if section.blocks.size > 0 -%}
          <ul class="mt-8 flex flex-wrap gap-4" role="list">
            {%- for block in section.blocks -%}
              <li class="flex items-center gap-2 text-sm" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  {{ block.settings.icon | image_url: width: 32 | image_tag: widths: '32', class: 'h-8 w-8' }}
                {%- endif -%}
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
      <div class="order-1 lg:order-2">
        {%- liquid
          assign hero_image = section.settings.image
          if section.settings.image_mobile != blank
            assign hero_image_mobile = section.settings.image_mobile
          else
            assign hero_image_mobile = section.settings.image
          endif
        -%}
        {%- if hero_image != blank -%}
          <div class="relative overflow-hidden rounded-2xl shadow-lg">
            {%- if section.settings.overlay_opacity > 0 -%}
              <div
                class="pointer-events-none absolute inset-0 z-10 rounded-2xl"
                style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"
                aria-hidden="true"
              ></div>
            {%- endif -%}
            <picture>
              {%- if section.settings.image_mobile != blank -%}
                <source media="(max-width: 1023px)" srcset="{{ hero_image_mobile | image_url: width: 800 }}">
              {%- endif -%}
              {%- render 'morbeez-lazy-image',
                image: hero_image,
                alt: section.settings.heading,
                loading: loading,
                fetchpriority: fetch,
                class: 'w-full h-auto object-cover',
                sizes: '(max-width: 1024px) 100vw, 50vw'
              -%}
            </picture>
          </div>
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-auto rounded-2xl' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.hero_premium.name",
  "tag": "section",
  "class": "section-hero-premium",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.hero_premium.settings.image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:sections.hero_premium.settings.image_mobile"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "%",
      "label": "t:sections.hero_premium.settings.overlay_opacity",
      "default": 0
    },
    {
      "type": "text",
      "id": "badge",
      "label": "t:sections.hero_premium.settings.badge",
      "default": "Trusted by farmers across India"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.hero_premium.settings.heading",
      "default": "Premium crop care for every season"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.hero_premium.settings.subheading",
      "default": "<p>Shop crop-wise solutions, expert-backed advisory, and fast delivery — all in one place.</p>"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "t:sections.hero_premium.settings.primary_cta_url"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "t:sections.hero_premium.settings.primary_cta_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "t:sections.hero_premium.settings.secondary_cta_url"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "t:sections.hero_premium.settings.secondary_cta_label",
      "default": "Talk on WhatsApp"
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "t:sections.hero_premium.blocks.trust_badge.name",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "t:sections.hero_premium.blocks.trust_badge.settings.icon" },
        { "type": "text", "id": "text", "label": "t:sections.hero_premium.blocks.trust_badge.settings.text", "default": "Quality assured" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero_premium.presets.default",
      "blocks": [
        { "type": "trust_badge", "settings": { "text": "Expert advisory" } },
        { "type": "trust_badge", "settings": { "text": "Fast delivery" } }
      ]
    }
  ]
}
{% endschema %}
