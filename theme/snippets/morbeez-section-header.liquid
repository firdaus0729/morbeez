{% comment %}
  Section header: title, subtitle, optional link
  Accepts: heading, subheading, link_url, link_label
{% endcomment %}
{%- if heading != blank -%}
  <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <div>
      <h2 class="font-heading text-2xl font-bold text-[var(--color-trust)] md:text-3xl">{{ heading }}</h2>
      {%- if subheading != blank -%}
        <p class="mt-2 text-[var(--color-muted)]">{{ subheading }}</p>
      {%- endif -%}
    </div>
    {%- if link_url != blank and link_label != blank -%}
      <a href="{{ link_url }}" class="text-sm font-semibold text-[var(--color-primary)] hover:underline">
        {{ link_label }} →
      </a>
    {%- endif -%}
  </div>
{%- endif -%}
