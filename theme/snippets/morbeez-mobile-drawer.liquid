<div
  id="morbeez-mobile-drawer"
  class="morbeez-drawer fixed inset-0 z-[60] hidden"
  aria-hidden="true"
  data-mobile-drawer
>
  <div class="absolute inset-0 bg-[var(--color-trust)]/40 backdrop-blur-sm" data-drawer-backdrop></div>
  <nav
    class="absolute right-0 top-0 flex h-full w-[min(100%,22rem)] flex-col bg-white shadow-2xl"
    role="dialog"
    aria-modal="true"
    aria-label="{{ 'accessibility.mobile_navigation' | t }}"
  >
    <div class="flex h-[4.25rem] items-center justify-between border-b border-[var(--color-border)] px-5">
      <span class="font-heading font-bold text-[var(--color-primary)]">{{ shop.name }}</span>
      <button
        type="button"
        class="morbeez-icon-btn"
        data-drawer-close
        aria-label="{{ 'accessibility.close' | t }}"
      >
        {%- render 'morbeez-icon', name: 'close', class: 'h-5 w-5' -%}
      </button>
    </div>
    <div class="flex-1 overflow-y-auto p-4">
      <ul class="space-y-1" role="list">
        {%- for link in linklists[menu].links -%}
          <li>
            {%- if link.links.size > 0 -%}
              <details class="group rounded-xl">
                <summary class="flex cursor-pointer list-none items-center justify-between rounded-xl px-4 py-3.5 text-sm font-medium text-[var(--color-trust)] hover:bg-[var(--color-surface)]">
                  {{ link.title }}
                  {%- render 'morbeez-icon', name: 'chevron-down', class: 'h-4 w-4 text-[var(--color-muted)]' -%}
                </summary>
                <ul class="ml-2 space-y-0.5 border-l-2 border-[var(--color-border)] py-2 pl-4" role="list">
                  {%- for child in link.links -%}
                    <li>
                      <a
                        href="{{ child.url }}"
                        class="block rounded-lg px-3 py-2.5 text-sm text-[var(--color-muted)] hover:bg-[var(--color-surface)] hover:text-[var(--color-primary)]"
                      >
                        {{ child.title }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              </details>
            {%- else -%}
              <a
                href="{{ link.url }}"
                class="block rounded-xl px-4 py-3.5 text-sm font-medium text-[var(--color-trust)] hover:bg-[var(--color-surface)] hover:text-[var(--color-primary)]"
              >
                {{ link.title }}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
    <div class="border-t border-[var(--color-border)] p-4">
      <a href="{{ routes.cart_url }}" class="morbeez-btn-primary w-full justify-center text-center">
        {{ 'general.cart' | t }} ({{ cart.item_count }})
      </a>
    </div>
  </nav>
</div>
