{% comment %}
  Collection/category tile
  Accepts: image, title, url, count_label, class
{% endcomment %}
<a
  href="{{ url }}"
  class="morbeez-card morbeez-tile group block w-[140px] shrink-0 overflow-hidden sm:w-[160px] {{ class }}"
>
  <div class="aspect-square overflow-hidden bg-[var(--color-surface)]">
    {%- if image != blank -%}
      {%- render 'morbeez-lazy-image',
        image: image,
        alt: title,
        class: 'h-full w-full object-cover transition group-hover:scale-105'
      -%}
    {%- else -%}
      <div class="flex h-full w-full items-center justify-center bg-[var(--color-primary)]/10 text-3xl">🌿</div>
    {%- endif -%}
  </div>
  <div class="p-3">
    <p class="text-sm font-semibold leading-snug text-[var(--color-trust)]">{{ title }}</p>
    {%- if count_label != blank -%}
      <p class="mt-0.5 text-xs text-[var(--color-muted)]">{{ count_label }}</p>
    {%- endif -%}
  </div>
</a>
