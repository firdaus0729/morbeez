# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=https://api-staging.morbeez.in
LOG_LEVEL=info

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Shopify
SHOPIFY_STORE_DOMAIN=morbeez.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2024-10
SHOPIFY_WEBHOOK_SECRET=whsec_...
SHOPIFY_APP_CLIENT_SECRET=shpss_...

# Outbox retry worker (polls failed events every 30s)
ENABLE_OUTBOX_WORKER=true

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=whsec_razorpay

# Shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_WEBHOOK_TOKEN=optional_shared_secret

# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=morbeez_verify_token_change_me
WHATSAPP_BUSINESS_ACCOUNT_ID=

# WATI (optional — set WHATSAPP_PROVIDER=wati|cloud)
WHATSAPP_PROVIDER=cloud
WATI_API_ENDPOINT=https://live-mt-server.wati.io
WATI_ACCESS_TOKEN=

# Interakt (optional alternative)
INTERAKT_API_KEY=

# Security
INTERNAL_API_KEY=generate_long_random_key_for_admin_routes
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Feature flags
ENABLE_SHIPROCKET_AUTO_SHIP=true
ENABLE_RAZORPAY_PAYMENT_LINKS=true
ENABLE_WHATSAPP_AUTO_REPLY=false
